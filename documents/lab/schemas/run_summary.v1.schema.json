{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dcp://apm2.local/lab/schemas/run_summary.v1",
  "title": "Run Summary v1",
  "type": "object",
  "required": [
    "run_id",
    "seed",
    "target_rfc_path",
    "completed",
    "stop_reason",
    "iterations_executed",
    "iterations_admitted",
    "final_quality",
    "total_delta_u",
    "total_cost",
    "total_tokens",
    "total_cli_calls",
    "total_elapsed_seconds",
    "critical_regression_count",
    "council_disagreement_mean",
    "final_rfc_hash",
    "summary_path",
    "events_path"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "seed": { "type": "integer", "minimum": 0 },
    "target_rfc_path": { "type": "string" },
    "branch_name": { "type": ["string", "null"] },
    "completed": { "type": "boolean" },
    "stop_reason": { "type": "string" },
    "iterations_executed": { "type": "integer", "minimum": 0 },
    "iterations_admitted": { "type": "integer", "minimum": 0 },
    "final_quality": { "$ref": "#/$defs/quality_vector" },
    "total_delta_u": { "type": "number" },
    "total_cost": { "type": "number" },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "total_cli_calls": { "type": "integer", "minimum": 0 },
    "total_elapsed_seconds": { "type": "number", "minimum": 0 },
    "critical_regression_count": { "type": "integer", "minimum": 0 },
    "council_disagreement_mean": { "type": "number", "minimum": 0 },
    "final_rfc_hash": { "type": "string" },
    "summary_path": { "type": "string" },
    "events_path": { "type": "string" }
  },
  "$defs": {
    "quality_vector": {
      "type": "object",
      "required": ["security", "robustness", "reliability", "performance", "implementability", "verifiability"],
      "properties": {
        "security": { "type": "number" },
        "robustness": { "type": "number" },
        "reliability": { "type": "number" },
        "performance": { "type": "number" },
        "implementability": { "type": "number" },
        "verifiability": { "type": "number" }
      }
    }
  }
}
